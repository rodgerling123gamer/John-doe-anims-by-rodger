-- Função para formatar o tempo de cooldown
local function formatCooldownTime(seconds)
	if seconds > 10 then
		return tostring(math.floor(seconds))
	else
		return string.format("%.1f", seconds)
	end
end

-- Função para iniciar o cooldown de uma habilidade
local function startCooldown(abilityName, duration)
	if cooldowns[abilityName] then
		cooldowns[abilityName].TimePast = 0
		cooldowns[abilityName].Duration = duration
		return
	end

	cooldowns[abilityName] = {
		Duration = duration,
		TimePast = 0,
	}
	local ui = abilityUIs[abilityName]
	if ui then
		ui.Clipping.Top.UIGradient.Offset = Vector2.new(0,0.5)
		local tween = TweenService:Create(ui.Clipping.Top.UIGradient, TweenInfo.new(duration), {Offset = Vector2.new(0, -0.5)})
		tween:Play()
	end
end

-- Função para atualizar o cooldown visualmente
local function updateCooldownVisual(abilityName, deltaTime)
	local cooldownData = cooldowns[abilityName]
	if not cooldownData then return end

	local abilityUI = abilityUIs[abilityName]
	if not abilityUI then return end

	local duration = cooldownData.Duration
	local timePast = cooldownData.TimePast

	local progress = math.clamp(timePast / duration, 0, 1)
	local remaining = duration - timePast


	-- Atualiza o texto do cooldown
	local cooldownTime = abilityUI:FindFirstChild("CooldownTime")
	if cooldownTime then
		if progress >= 1 then
			cooldownTime.Text = ""
		else
			cooldownTime.Text = formatCooldownTime(remaining)
		end
	end

	-- Incrementa o tempo passado
	cooldownData.TimePast = cooldownData.TimePast + deltaTime

	-- Remove o cooldown se completou
	-- Remove o cooldown se completou
	if cooldownData.TimePast >= duration then
		cooldowns[abilityName] = nil
	end
end
function AbilitySystem.IsOnCooldown(abilityName)
	return cooldowns[abilityName] ~= nil
end
function AbilitySystem.GetCooldownRemaining(abilityName)
	local cooldownData = cooldowns[abilityName]
	if not cooldownData then return 0 end
	return math.max(0, cooldownData.Duration - cooldownData.TimePast)
end
function AbilitySystem.RegisterAbility(abilityData)
	if not abilityData.Name then
		error("AbilitySystem: Nome da habilidade é obrigatório")
	end

	abilities[abilityData.Name] = {
		Name = abilityData.Name,
		Icon = abilityData.Icon or DEFAULT_CONFIG.DefaultIcon,
		Cooldown = abilityData.Cooldown or 5,
		Keybind = abilityData.Keybind or "",
		Charges = abilityData.Charges,
		MaxCharges = abilityData.MaxCharges or abilityData.Charges,
		LayoutOrder = abilityData.LayoutOrder or 1,
		Callback = abilityData.Callback or function() end,
		Disabled = false,
	}

	return abilities[abilityData.Name]
end
function AbilitySystem.UseAbility(abilityName, ...)
	local ability = abilities[abilityName]
	if not ability then
		warn("AbilitySystem: Habilidade '" .. abilityName .. "' não encontrada")
		return false
	end

	if ability.Disabled then
		return false
	end

	-- Verifica se está em cooldown
	if AbilitySystem.IsOnCooldown(abilityName) then
		return false
	end

	-- Verifica cargas
	if ability.Charges and ability.Charges <= 0 then
		return false
	end

	-- Executa o callback
	local success, result = pcall(ability.Callback, ability, ...)
	if not success then
		warn("AbilitySystem: Erro ao executar habilidade '" .. abilityName .. "': " .. tostring(result))
		return false
	end

	-- Inicia o cooldown
	startCooldown(abilityName, ability.Cooldown)

	-- Decrementa cargas se aplicável
	if ability.Charges then
		ability.Charges = ability.Charges - 1

		-- Atualiza o visual das cargas
		local abilityUI = abilityUIs[abilityName]
		if abilityUI then
			local chargesLabel = abilityUI:FindFirstChild("Charges")
			if chargesLabel then
				chargesLabel.Text = tostring(ability.Charges)

				if ability.Charges <= 0 then
					ability.Disabled = true
					-- Visual de desabilitado
					abilityUI.ImageColor3 = Color3.fromRGB(50, 50, 50)
				end
			end
		end
	end

	return true
end

-- Função para atualizar cargas
function AbilitySystem.UpdateCharges(abilityName, newCharges)
	local ability = abilities[abilityName]
	if not ability then return end

	ability.Charges = newCharges

	local abilityUI = abilityUIs[abilityName]
	if abilityUI then
		local chargesLabel = abilityUI:FindFirstChild("Charges")
		if chargesLabel then
			chargesLabel.Text = tostring(newCharges)
		end

		if newCharges > 0 then
			ability.Disabled = false
			abilityUI.ImageColor3 = Color3.fromRGB(100, 100, 100)
		else
			ability.Disabled = true
			abilityUI.ImageColor3 = Color3.fromRGB(50, 50, 50)
		end
	end
end

-- Função para adicionar cargas
function AbilitySystem.AddCharges(abilityName, amount)
	local ability = abilities[abilityName]
	if not ability or not ability.MaxCharges then return end

	local newCharges = math.min(ability.Charges + amount, ability.MaxCharges)
	AbilitySystem.UpdateCharges(abilityName, newCharges)
end

-- Função para definir o cooldown
function AbilitySystem.SetCooldown(abilityName, duration)
	if duration > 0 then
		startCooldown(abilityName, duration)
	else
		cooldowns[abilityName] = nil

		local abilityUI = abilityUIs[abilityName]
		if abilityUI then
			local clipping = abilityUI:FindFirstChild("Clipping")
			if clipping then
				clipping.Size = UDim2.new(1, 0, 1, 0)
				local top = clipping:FindFirstChild("Top")
				if top then
					top.Size = UDim2.new(1, 0, 1, 0)
				end
			end

			local cooldownTime = abilityUI:FindFirstChild("CooldownTime")
			if cooldownTime then
				cooldownTime.Text = ""
			end
		end
	end
end

-- Função para desabilitar/habilitar uma habilidade
function AbilitySystem.SetAbilityDisabled(abilityName, disabled)
	local ability = abilities[abilityName]
	if not ability then return end

	ability.Disabled = disabled

	local abilityUI = abilityUIs[abilityName]
	if abilityUI then
		abilityUI.ImageColor3 = disabled and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(100, 100, 100)
