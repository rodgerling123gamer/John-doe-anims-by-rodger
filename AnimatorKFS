-- Função para destruir o sistema
function AbilitySystem.Destroy()
	-- Desconecta todas as conexões
	for _, connection in ipairs(connections) do
		if connection.Connected then
			connection:Disconnect()
		end
	end
	table.clear(connections)

	-- Remove as UIs
	for _, abilityUI in pairs(abilityUIs) do
		if abilityUI.Parent then
			abilityUI:Destroy()
		end
	end
	table.clear(abilityUIs)

	-- Remove o container
	if container and container.Parent then
		container:Destroy()
	end
	container = nil

	-- Limpa os cooldowns
	table.clear(cooldowns)

	isInitialized = false
end

