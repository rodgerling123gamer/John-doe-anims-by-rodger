function PlaySound(SoundName)
	pcall(function()
		local Proprieties = Sounds[SoundName or "click"]
		local Sound = Instance.new("Sound", game.ReplicatedStorage)
		if typeof(Proprieties) == "table" then
			Sound.PlaybackSpeed = Proprieties.PlaybackSpeed or 1
			Sound.SoundId = Proprieties.SoundId or Sounds.click
		elseif typeof(Proprieties) == "string" then
			Sound.SoundId = Proprieties
		end
		Sound:Play()
		if not Sound.IsLoaded then
			Sound.Loaded:Wait()
			game.Debris:AddItem(Sound, Sound.TimeLength)
		else
			game.Debris:AddItem(Sound, Sound.TimeLength)
		end
	end)
end
