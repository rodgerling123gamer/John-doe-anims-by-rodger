-- Função para inicializar o sistema de habilidades
function AbilitySystem.Initialize(parentGui)
	if isInitialized then
		warn("AbilitySystem: Já foi inicializado")
		return
	end

	isInitialized = true

	-- Cria o container (se necessário)
	-- container = createAbilityContainer(parentGui)

	local container = Gui:FindFirstChild("AbilityContainer")
	if not container then
		container = Instance.new("Frame")
		container.Name = "AbilityContainer"
		container.Parent = parentGui
	end

	-- Cria as UIs para cada habilidade registrada
	for abilityName, abilityData in pairs(abilities) do
		local abilityIcon = createAbilityIcon(abilityData)
		abilityIcon.Parent = container
		abilityUIs[abilityName] = abilityIcon

		-- Conecta o clique
		if abilityIcon:IsA("GuiButton") then
			local clickConnection = abilityIcon.MouseButton1Click:Connect(function()
				AbilitySystem.UseAbility(abilityName)
			end)
			table.insert(connections, clickConnection)
		end

		-- Conecta o keybind
		if abilityData.Keybind and abilityData.Keybind ~= "" then
			local keybindName = abilityData.Keybind
			local keyCode = Enum.KeyCode[keybindName] or Enum.UserInputType[keybindName]

			if keyCode then
				local keybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
					if gameProcessed then return end

					if (input.KeyCode == keyCode) or (input.UserInputType == keyCode) then
						AbilitySystem.UseAbility(abilityName)
					end
				end)
				table.insert(connections, keybindConnection)
			else
				warn("AbilitySystem: Keybind inválido para a habilidade '" .. abilityName .. "' -> '" .. keybindName .. "'")
			end
		end
	end

	-- Loop de atualização de cooldowns
	local cooldownConnection = RunService.RenderStepped:Connect(function(deltaTime)
		for abilityName, _ in pairs(cooldowns) do
			updateCooldownVisual(abilityName, deltaTime)
		end
	end)
	table.insert(connections, cooldownConnection)

	return container
end
