function ScriptHub:CreateSlider(Name, Title, Desc, Min, Max, Step, Callback)
	local UIS = game:GetService("UserInputService")
	local TweenService = game:GetService("TweenService")
	local Player = game.Players.LocalPlayer
	local Mouse = Player:GetMouse()

	Min = Min or 0
	Max = Max or 100
	Step = Step or 1

	local Value = Min
	local Dragging = false

	local UITemplate = Instance.new('Frame', Gui:WaitForChild("Container"):WaitForChild("DetailContainer"):WaitForChild("Contents"))
	UITemplate.Name = "Slider"..Name
	UITemplate.Size = UDim2.new(0.7, 0,0.075, 25)
	UITemplate.AnchorPoint = Vector2.new(0.5,0.5)
	UITemplate.BackgroundTransparency = 1

	local DragBarBackground = Instance.new("ImageLabel", UITemplate)
	DragBarBackground.BackgroundTransparency = 1
	DragBarBackground.Position = UDim2.new(0.875,0,0.5,0)
	DragBarBackground.Size = UDim2.new(0.5, 0,0.725, 0)
	DragBarBackground.AnchorPoint = Vector2.new(0.5,0.5)
	DragBarBackground.Image = "rbxassetid://125225912214611"
	DragBarBackground.ImageColor3 = Color3.new(0,0,0)

	local DragBar = Instance.new("Frame", UITemplate)
	DragBar.BackgroundTransparency = 1
	DragBar.Size = UDim2.new(0.4, 0,0.725, 0)
	DragBar.AnchorPoint = Vector2.new(0.5,0.5)
	DragBar.Position = UDim2.new(0.875, 0,0.5, 0)

	local Dragger = Instance.new("ImageButton", DragBar)
	Dragger.Position = UDim2.new(0, 0,0.5,0)
	Dragger.ImageColor3 = Color3.fromRGB(219, 219, 219)
	Dragger.BackgroundTransparency = 1
	Dragger.AnchorPoint = Vector2.new(0.5,0.5)
	Dragger.Image = "rbxassetid://130893928901265"
	Dragger.Size = UDim2.new(0.5, 0,0.75, 0)

	local UIAspectRatioConstraint = Instance.new("UIAspectRatioConstraint", Dragger)
	UIAspectRatioConstraint.AspectRatio = 1

	local ValueLabel = Instance.new("TextLabel", Dragger)
	ValueLabel.Text = tostring(Value)
	ValueLabel.TextColor3 = Color3.new(1,1,1)
	ValueLabel.BackgroundTransparency = 1
	ValueLabel.Size = UDim2.new(2,0,1,0)
	ValueLabel.Position = UDim2.new(1,0,0,0)

	local SettingName = Instance.new("TextLabel", UITemplate)
	SettingName.Text = Title or Name
	SettingName.TextColor3 = Color3.new(1,1,1)
	SettingName.Font = Enum.Font.Bodoni
	SettingName.TextSize = 20
	SettingName.BackgroundTransparency = 1
	SettingName.Size = UDim2.new(0.6,0,0.65,0)

	local SettingDesc = Instance.new("TextLabel", UITemplate)
	SettingDesc.Text = Desc or ""
	SettingDesc.TextColor3 = Color3.new(1,1,1)
	SettingDesc.Font = Enum.Font.Bodoni
	SettingDesc.TextSize = 14
	SettingDesc.BackgroundTransparency = 1
	SettingDesc.Position = UDim2.new(0,0,1,0)
	SettingDesc.Size = UDim2.new(0.7,0,0.4,0)

	-- FUNÇÃO DE ATUALIZAÇÃO
	local function UpdateSlider(newValue)
		newValue = math.clamp(newValue, Min, Max)

		-- aplicar step
		if Step > 0 then
			newValue = math.floor((newValue + Step/2)/Step)*Step
		end

		if Value ~= newValue then
			Value = newValue
			ValueLabel.Text = tostring(Value)
			--PlaySound("tick"..math.random(1,3))

			local percent = (Value - Min) / (Max - Min)

			Dragger.Position = UDim2.fromScale(percent, 0.5)

			if Callback then
				Callback(Value)
			end
		end
	end

	-- DRAG SYSTEM
	Dragger.MouseButton1Down:Connect(function()
		Dragging = true
	end)

	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			Dragging = false
			PlaySound("switch".. math.random(1,3));
		end
	end)

	UIS.InputChanged:Connect(function()
		if Dragging then
			local percent = (Mouse.X - DragBar.AbsolutePosition.X) / DragBar.AbsoluteSize.X
			local newValue = Min + (Max - Min) * percent
			UpdateSlider(newValue)
		end
	end)

	-- inicial
	UpdateSlider(Value)

	return {
		SetValue = UpdateSlider,
		GetValue = function()
			return Value
		end
	}
end
