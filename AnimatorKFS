local RunService = game:GetService("RunService")

local Animator = {}
Animator.__index = Animator

local function lerpCFrame(a, b, t)
	return a:Lerp(b, t)
end

function Animator.new(character, keyframeSequence)
	local self = setmetatable({}, Animator)

	self.Character = character
	self.KeyframeSequence = keyframeSequence
	self.Time = 0
	self.Speed = 1
	self.Playing = false

	self.Joints = {}

	for _, v in pairs(character:GetDescendants()) do
		if v:IsA("Motor6D") then
			self.Joints[v.Name] = v
		end
	end

	self.Keyframes = keyframeSequence:GetKeyframes()
	table.sort(self.Keyframes, function(a, b)
		return a.Time < b.Time
	end)

	return self
end

function Animator:Play(speed)
	self.Speed = speed or 1
	self.Time = 0
	self.Playing = true
end

function Animator:Stop()
	self.Playing = false
end

function Animator:Step(dt)
	if not self.Playing then return end

	self.Time += dt * self.Speed

	local kfs = self.Keyframes
	if #kfs < 2 then return end

	local kf1, kf2

	for i = 1, #kfs - 1 do
		if self.Time >= kfs[i].Time and self.Time <= kfs[i+1].Time then
			kf1 = kfs[i]
			kf2 = kfs[i+1]
			break
		end
	end

	if not kf1 or not kf2 then return end

	local alpha = (self.Time - kf1.Time) / (kf2.Time - kf1.Time)

	for _, pose in pairs(kf1:GetDescendants()) do
		if pose:IsA("Pose") then
			local joint = self.Joints[pose.Name]
			if joint then
				local pose2 = kf2:FindFirstChild(pose.Name, true)
				if pose2 and pose2:IsA("Pose") then
					joint.Transform = lerpCFrame(pose.CFrame, pose2.CFrame, alpha)
				end
			end
		end
	end
end

function Animator:Bind()
	self.Connection = RunService.RenderStepped:Connect(function(dt)
		self:Step(dt)
	end)
end

function Animator:Destroy()
	if self.Connection then
		self.Connection:Disconnect()
	end
end
return Animator
